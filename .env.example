# ============================================================
# ANITA ChatBot — Dr. Jorge Hara
# Conectado a CitaMedica producción: https://micitamedica.me/api
# ============================================================

# --- Backend CitaMedica (OBLIGATORIO) ---
# URL base de la API de CitaMedica en producción
API_URL=https://micitamedica.me/api

# API Key para autenticar el chatbot con el backend
# Debe coincidir con CHATBOT_API_KEY en el .env del backend de CitaMedicaBeta
CHATBOT_API_KEY=e7816ab03723e353ff4ef0a632e293f2f968d1a79e56c82590cfd81113b54fe3

# Subdominio del tenant en CitaMedica (identifica la clínica)
# Para Dr. Jorge Hara usar el subdominio configurado en CitaMedicaBeta
TENANT_SUBDOMAIN=dr-jorgehara

# --- MongoDB (OBLIGATORIO) ---
# URI de conexión a MongoDB para persistir sesiones de BuilderBot
MONGO_DB_URI=mongodb://localhost:27017/chatbot-drjorgehara

# Nombre de la base de datos
MONGO_DB_NAME=chatbot-drjorgehara

# --- Puertos (OPCIONAL — defaults seguros) ---
# Puerto del servidor BuilderBot (WhatsApp)
PORT=3008

# Puerto del servidor Express (health check / endpoints internos)
EXPRESS_PORT=3009

# --- IA — Claude Haiku (OBLIGATORIO para extracción de intención) ---
# API Key de Anthropic para Claude Haiku
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Google Calendar (OPCIONAL — para lectura de slots disponibles) ---
# ID del calendario de Google del Dr. Jorge Hara
# Formato: xxxxx@group.calendar.google.com o email del calendario
GOOGLE_CALENDAR_ID=701534e166df3c40c105a8d7f31bc845da6bae8f661e02b50f33c06618b240a4@group.calendar.google.com

# Ruta al archivo de credenciales de Service Account de Google
# Default: ./google.json.txt (colocar el archivo en la raíz del proyecto)
GOOGLE_SERVICE_ACCOUNT_PATH=./google.json

# Horario de atención del Dr. Jorge Hara para el calendario
# Formato: hora en número entero (24h, BsAs)
WORK_START_HOUR=8
WORK_END_HOUR=18

# Días hábiles (0=Dom,1=Lun,2=Mar,3=Mié,4=Jue,5=Vie,6=Sáb)
# Ejemplo: "1,2,3,4,5" = Lunes a Viernes
WORK_DAYS=1,2,3,4,5

# --- Admin (OPCIONAL) ---
# Número de WhatsApp del administrador (formato: código_país + número sin +)
# Ejemplo: 5493794051686
ADMIN_NUMBER=

# Número de teléfono de emergencia/urgencias mostrado al paciente
EMERGENCY_PHONE_NUMBER=+5493794051686
